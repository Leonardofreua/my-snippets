#!/usr/bin/env bash

ACTION="$2"

# Only react to useful events
case "$ACTION" in
    up|connectivity-change)
        ;;
    *)
        exit 0
        ;;
esac

USER_NAME=$(loginctl list-sessions --no-legend | awk '{print $3}' | head -n1)

if [[ -z "$USER_NAME" ]]; then
    exit 0
fi

USER_ID=$(id -u "$USER_NAME")
BUS_PATH="/run/user/$USER_ID/bus"

if [[ ! -S "$BUS_PATH" ]]; then
    exit 0
fi

runuser -u "$USER_NAME" -- \
    env DBUS_SESSION_BUS_ADDRESS="unix:path=$BUS_PATH" \
    "/home/$USER_NAME/scripts/wifi_idle_policy.sh"

exit 0